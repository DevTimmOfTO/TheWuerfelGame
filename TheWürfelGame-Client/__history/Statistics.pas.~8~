unit Statistics;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics, System.Generics.Collections,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, VclTee.TeeGDIPlus, VCLTee.TeEngine,
  VCLTee.Series, Vcl.ExtCtrls, VCLTee.TeeProcs, VCLTee.Chart, Vcl.StdCtrls;

type
  TForm3 = class(TForm)
    GroupBox1: TGroupBox;
    GroupBox2: TGroupBox;
    Label1: TLabel;
    Label2: TLabel;
    Label3: TLabel;
    Label4: TLabel;
    Label5: TLabel;
    Label6: TLabel;
    Edit1: TEdit;
    Edit2: TEdit;
    Edit3: TEdit;
    Edit4: TEdit;
    Edit5: TEdit;
    Edit6: TEdit;
    Edit7: TEdit;
    Edit8: TEdit;
    Edit9: TEdit;
    Edit10: TEdit;
    Edit11: TEdit;
    Edit12: TEdit;
    Label7: TLabel;
    Label8: TLabel;
    Label9: TLabel;
    Label10: TLabel;
    Label11: TLabel;
    Label12: TLabel;
    Label13: TLabel;
    Label14: TLabel;
    Edit13: TEdit;
    Edit14: TEdit;
    Chart1: TChart;
    Series2: TPieSeries;
    procedure FormCreate(Sender: TObject);
  private
    { Private-Deklarationen }
  public
    { Public-Deklarationen }
  end;

var
  Form3: TForm3;
  SWŘrfel1: array of Integer;
  SWŘrfel2: array of Integer;
  SWŘrfel3: array of Integer;
  SWŘrfel4: array of Integer;
  SWŘrfel5: array of Integer;
implementation

{$R *.dfm}

procedure TForm3.FormCreate(Sender: TObject);
var
  GesamtListe: TList<Integer>;
  Hńufigkeit: array[1..6] of Integer;
  Relativ: array[1..6] of Double;
  i, Wert, GesamtAnzahl: Integer;
  MaxHńufigkeit, MinHńufigkeit, Hńufigster, Seltenster: Integer;
begin
// Load Data
  GesamtListe := TList<Integer>.Create;
  try
    // Alle Arrays zusammenfŘhren
    for Wert in SWŘrfel1 do GesamtListe.Add(Wert);
    for Wert in SWŘrfel2 do GesamtListe.Add(Wert);
    for Wert in SWŘrfel3 do GesamtListe.Add(Wert);
    for Wert in SWŘrfel4 do GesamtListe.Add(Wert);
    for Wert in SWŘrfel5 do GesamtListe.Add(Wert);

    // Initialisieren
    FillChar(Hńufigkeit, SizeOf(Hńufigkeit), 0);

    // Absolute Hńufigkeit zńhlen
    for Wert in GesamtListe do
      if (Wert >= 1) and (Wert <= 6) then
        Inc(Hńufigkeit[Wert]);

    // Gesamtanzahl
    GesamtAnzahl := GesamtListe.Count;

    // Relative Hńufigkeit berechnen
    for i := 1 to 6 do
      if GesamtAnzahl > 0 then
        Relativ[i] := Hńufigkeit[i] / GesamtAnzahl
      else
        Relativ[i] := 0;

    // Hńufigster und seltenster Wert finden
    MaxHńufigkeit := -1;
    MinHńufigkeit := MaxInt;
    for i := 1 to 6 do
    begin
      if Hńufigkeit[i] > MaxHńufigkeit then
      begin
        MaxHńufigkeit := Hńufigkeit[i];
        Hńufigster := i;
      end;
      if (Hńufigkeit[i] < MinHńufigkeit) and (Hńufigkeit[i] > 0) then
      begin
        MinHńufigkeit := Hńufigkeit[i];
        Seltenster := i;
      end;
    end;

    // GUI: Absolute Hńufigkeit eintragen
    Edit7.Text := IntToStr(Hńufigkeit[1]);
    Edit10.Text := IntToStr(Hńufigkeit[2]);
    Edit8.Text := IntToStr(Hńufigkeit[3]);
    Edit11.Text := IntToStr(Hńufigkeit[4]);
    Edit9.Text := IntToStr(Hńufigkeit[5]);
    Edit12.Text := IntToStr(Hńufigkeit[6]);

    // GUI: Relative Hńufigkeit eintragen
    Edit1.Text := Format('%.2f %%', [Relativ[1] * 100]);
    Edit4.Text := Format('%.2f %%', [Relativ[2] * 100]);
    Edit2.Text := Format('%.2f %%', [Relativ[3] * 100]);
    Edit5.Text := Format('%.2f %%', [Relativ[4] * 100]);
    Edit3.Text := Format('%.2f %%', [Relativ[5] * 100]);
    Edit6.Text := Format('%.2f %%', [Relativ[6] * 100]);

    // Hńufigste/wenigste Werte eintragen
    Edit13.Text := Format('%d (%dÎ)', [Hńufigster, MaxHńufigkeit]);
    Edit14.Text := Format('%d (%dÎ)', [Seltenster, MinHńufigkeit]);

    // Kreisdiagramm (Series2) aktualisieren
    Series2.Clear;
    for i := 1 to 6 do
      if Hńufigkeit[i] > 0 then
        Series2.Add(Hńufigkeit[i], IntToStr(i), clTeeColor); // Automatische Farbe;
  finally
    GesamtListe.Free;
  end;
end;

end.
