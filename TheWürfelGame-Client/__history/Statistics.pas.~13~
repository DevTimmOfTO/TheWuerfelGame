  Form3: TForm3;

implementation

{$R *.dfm}

uses MainPlayer1;

procedure TForm3.UpdateStatistics;
var
  GesamtListe: TList<Integer>;
  Häufigkeit: array [1 .. 6] of Integer;
  Relativ: array [1 .. 6] of Double;
  i, Wert, GesamtAnzahl: Integer;
  MaxHäufigkeit, MinHäufigkeit, Häufigster, Seltenster, Summe: Integer;
  Mittelwert:real;
begin
  // Load Data
  GesamtListe := TList<Integer>.Create;
  try
    // Alle Arrays zusammenführen
    for Wert in Würfel1 do
      GesamtListe.Add(Wert);
    for Wert in Würfel2 do
      GesamtListe.Add(Wert);
    for Wert in Würfel3 do
      GesamtListe.Add(Wert);
    for Wert in Würfel4 do
      GesamtListe.Add(Wert);
    for Wert in Würfel5 do
      GesamtListe.Add(Wert);

    // Initialisieren
    FillChar(Häufigkeit, SizeOf(Häufigkeit), 0);

    // Absolute Häufigkeit zählen
    for Wert in GesamtListe do
      if (Wert >= 1) and (Wert <= 6) then
        Inc(Häufigkeit[Wert]);

    // Gesamtanzahl
    GesamtAnzahl := GesamtListe.Count;

    // Relative Häufigkeit berechnen
    for i := 1 to 6 do
      if GesamtAnzahl > 0 then
        Relativ[i] := Häufigkeit[i] / GesamtAnzahl
      else
        Relativ[i] := 0;

    // Häufigster und seltenster Wert finden
    MaxHäufigkeit := -1;
    MinHäufigkeit := MaxInt;
    for i := 1 to 6 do
    begin
      if Häufigkeit[i] > MaxHäufigkeit then
      begin
        MaxHäufigkeit := Häufigkeit[i];
        Häufigster := i;
      end;
      if (Häufigkeit[i] < MinHäufigkeit) and (Häufigkeit[i] > 0) then
      begin
        MinHäufigkeit := Häufigkeit[i];
        Seltenster := i;
      end;
    end;

    // GUI: Absolute Häufigkeit eintragen
    Edit7.Text := IntToStr(Häufigkeit[1]);
    Edit10.Text := IntToStr(Häufigkeit[2]);
    Edit8.Text := IntToStr(Häufigkeit[3]);
    Edit11.Text := IntToStr(Häufigkeit[4]);
    Edit9.Text := IntToStr(Häufigkeit[5]);
    Edit12.Text := IntToStr(Häufigkeit[6]);

    // GUI: Relative Häufigkeit eintragen
    Edit1.Text := Format('%.2f %%', [Relativ[1] * 100]);
    Edit4.Text := Format('%.2f %%', [Relativ[2] * 100]);
    Edit2.Text := Format('%.2f %%', [Relativ[3] * 100]);
    Edit5.Text := Format('%.2f %%', [Relativ[4] * 100]);
    Edit3.Text := Format('%.2f %%', [Relativ[5] * 100]);
    Edit6.Text := Format('%.2f %%', [Relativ[6] * 100]);

    // Häufigste/wenigste Werte eintragen
    Edit13.Text := Format('%d (%d×)', [Häufigster, MaxHäufigkeit]);
    Edit14.Text := Format('%d (%d×)', [Seltenster, MinHäufigkeit]);

    // Mittelwert
    Summe := 0;
    for Wert in GesamtListe do
      Summe := Summe + Wert;

    if GesamtAnzahl > 0 then
      Mittelwert := Summe / GesamtAnzahl
    else
      Mittelwert := 0;

    Edit15.Text := Format('%.2f', [Mittelwert]);

    // Kreisdiagramm (Series2) aktualisieren
    Series2.Clear;
    for i := 1 to 6 do
      if Häufigkeit[i] > 0 then
        Series2.Add(Häufigkeit[i], IntToStr(i), clTeeColor);
    // Automatische Farbe;
  finally
    GesamtListe.Free;
  end;
end;

end.
